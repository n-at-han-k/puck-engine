<div class="puck-engine-editor" data-controller="puck-editor">
  <div class="editor-header">
    <h1>Create New Page</h1>
    <%= link_to "Back to Pages", editor_index_path, class: "btn" %>
  </div>
  
  <%= form_with model: @page, url: editor_index_path, local: true do |form| %>
    <% if @page.errors.any? %>
      <div class="errors">
        <h2><%= pluralize(@page.errors.count, "error") %> prohibited this page from being saved:</h2>
        <ul>
          <% @page.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    
    <div class="field">
      <%= form.label :title %>
      <%= form.text_field :title %>
    </div>
    
    <div class="field">
      <%= form.label :slug %>
      <%= form.text_field :slug %>
    </div>
    
    <div class="field">
      <%= form.label :description %>
      <%= form.text_area :description %>
    </div>
    
    <div class="field">
      <%= form.label :published %>
      <%= form.check_box :published %>
    </div>
    
    <div class="actions">
      <%= form.submit "Create Page", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
