<div class="puck-pages-index">
  <h1>Pages</h1>
  
  <div class="pages-grid">
    <% @pages.each do |page| %>
      <div class="page-card">
        <h3><%= link_to page.title, page_path(page) %></h3>
        <p><%= page.description %></p>
        <span class="badge <%= page.published? ? 'published' : 'draft' %>">
          <%= page.published? ? "Published" : "Draft" %>
        </span>
      </div>
    <% end %>
  </div>
</div>
